---
// Lightbox partilhado.
// Triggers devem ter:
//   data-lightbox-src      — URL da imagem a mostrar
//   data-lightbox-caption  — legenda (opcional)
//   data-lightbox-pessoas  — JSON: [{id, nome}]  (opcional)
---

<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90"
  role="dialog"
  aria-modal="true"
>
  <button id="lb-prev" class="absolute left-3 top-1/2 -translate-y-1/2 text-white/50 hover:text-white text-5xl leading-none px-2 select-none" aria-label="Anterior">&#8249;</button>
  <button id="lb-next" class="absolute right-3 top-1/2 -translate-y-1/2 text-white/50 hover:text-white text-5xl leading-none px-2 select-none" aria-label="Seguinte">&#8250;</button>
  <button id="lb-close" class="absolute top-4 right-4 text-white/50 hover:text-white text-2xl leading-none px-2 select-none" aria-label="Fechar">&#10005;</button>
  <a id="lb-download" href="#" download class="hidden absolute bottom-4 right-4 text-xs text-white/30 hover:text-white/70 transition-colors" title="Descarregar original">
    ↓ original
  </a>

  <figure class="flex flex-col items-center gap-3 max-w-[90vw] max-h-[90vh] px-12">
    <img id="lb-img" src="" alt="" class="max-w-full max-h-[78vh] object-contain rounded shadow-2xl" />
    <figcaption class="text-center space-y-1.5">
      <p id="lb-caption" class="text-sm text-white/60 px-4"></p>
      <div id="lb-pessoas" class="flex flex-wrap justify-center gap-2"></div>
    </figcaption>
  </figure>
</div>

<script>
  const lb        = document.getElementById('lightbox')!;
  const lbImg     = document.getElementById('lb-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lb-caption')!;
  const lbPessoas = document.getElementById('lb-pessoas')!;
  const lbClose    = document.getElementById('lb-close')!;
  const lbPrev     = document.getElementById('lb-prev')!;
  const lbNext     = document.getElementById('lb-next')!;
  const lbDownload = document.getElementById('lb-download') as HTMLAnchorElement;

  const items = Array.from(document.querySelectorAll<HTMLElement>('[data-lightbox-src]'));
  let current = 0;
  let triggerEl: HTMLElement | null = null;

  // Elementos focáveis dentro do lightbox (para focus trap)
  const focusable = [lbPrev, lbNext, lbClose];

  function show(index: number) {
    current = (index + items.length) % items.length;
    const el = items[current];

    lbImg.src = el.dataset.lightboxSrc ?? '';
    lbImg.alt = el.dataset.lightboxCaption ?? '';
    lbCaption.textContent = el.dataset.lightboxCaption ?? '';

    // Link para descarregar original
    const original = el.dataset.lightboxOriginal;
    if (original) {
      lbDownload.href = original;
      lbDownload.classList.remove('hidden');
    } else {
      lbDownload.classList.add('hidden');
    }

    // Links para pessoas associadas
    lbPessoas.innerHTML = '';
    const pessoasRaw = el.dataset.lightboxPessoas;
    if (pessoasRaw) {
      try {
        const pessoas: { id: string; nome: string }[] = JSON.parse(pessoasRaw);
        for (const p of pessoas) {
          const a = document.createElement('a');
          a.href = `/pessoas/${p.id}`;
          a.textContent = p.nome;
          a.className = 'text-xs px-2.5 py-1 rounded-full bg-white/10 text-white/80 hover:bg-amber-500 hover:text-white transition-colors';
          lbPessoas.appendChild(a);
        }
      } catch {}
    }

    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';

    // Mover foco para o botão de fechar
    lbClose.focus();
  }

  function open(index: number, trigger: HTMLElement) {
    triggerEl = trigger;
    show(index);
  }

  function close() {
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    document.body.style.overflow = '';

    // Devolver foco ao elemento que abriu o lightbox
    triggerEl?.focus();
    triggerEl = null;
  }

  items.forEach((el, i) => el.addEventListener('click', () => open(i, el)));
  lbClose.addEventListener('click', close);
  lbPrev.addEventListener('click', () => show(current - 1));
  lbNext.addEventListener('click', () => show(current + 1));
  lb.addEventListener('click', (e) => { if (e.target === lb) close(); });

  document.addEventListener('keydown', (e) => {
    if (lb.classList.contains('hidden')) return;
    if (e.key === 'Escape') { close(); return; }
    if (e.key === 'ArrowLeft')  { show(current - 1); return; }
    if (e.key === 'ArrowRight') { show(current + 1); return; }

    // Focus trap: Tab e Shift+Tab circulam pelos botões do lightbox
    if (e.key === 'Tab') {
      // Incluir links de pessoas gerados dinamicamente
      const links = Array.from(lbPessoas.querySelectorAll<HTMLElement>('a'));
      const trappable = [...focusable, ...links];
      const first = trappable[0];
      const last  = trappable[trappable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last)  { e.preventDefault(); first.focus(); }
      }
    }
  });
</script>
