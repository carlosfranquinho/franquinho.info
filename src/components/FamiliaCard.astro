---
import type { Pessoa, MediaItem, Lugar } from '../types';
import { silhueta, eRetrato, formatarNome } from '../utils';

interface Props {
  pessoa: Pessoa;
  mediaMap: Record<string, MediaItem>;
  lugaresMap: Record<string, Lugar>;
  compact?: boolean;
}

const { pessoa, mediaMap, lugaresMap, compact = false } = Astro.props;

const nome = formatarNome(pessoa);

const thumb = pessoa.media
  ? (pessoa.media.map((id) => mediaMap[id]).filter(Boolean).find(eRetrato)?.thumb ?? null)
  : null;

const iniciais = nome.split(' ').filter(Boolean).slice(0, 2).map((w) => w[0]).join('').toUpperCase();

const anoNasc = pessoa.nascimento?.data?.match(/(\d{4})/)?.[1];
const anoObit = pessoa.obito?.data?.match(/(\d{4})/)?.[1];
const avatarSrc = silhueta(pessoa.sexo, anoNasc, anoObit);
const lugarNasc = pessoa.nascimento?.lugar_id ? lugaresMap[pessoa.nascimento.lugar_id] : null;
// Label "Freguesia, Concelho" sem link (card já é <a>)
const lugarNascLabel = (() => {
  if (!lugarNasc) return null;
  const pai = lugarNasc.pai_id ? lugaresMap[lugarNasc.pai_id] : null;
  const mostrarPai = pai?.nome && pai.pai_id;
  return mostrarPai ? `${lugarNasc.nome}, ${pai.nome}` : lugarNasc.nome;
})();
---

{compact ? (
  <!-- Compact: linha horizontal, largura fixa -->
  <a
    href={`/pessoas/${pessoa.id}`}
    class="flex items-center gap-3 px-3 py-2 rounded-lg border transition-all group w-52 shrink-0 border-stone-200 bg-white hover:border-amber-400 hover:shadow-sm"
  >
    <!-- Avatar pequeno -->
    <div class="flex-shrink-0 w-10 h-10 rounded-full overflow-hidden">
      {thumb ? (
        <img src={thumb} alt={nome} class="w-full h-full object-cover" loading="lazy" />
      ) : (
        <img src={avatarSrc} alt="" class="w-full h-full object-cover" loading="lazy" />
      )}
    </div>
    <!-- Nome e data -->
    <div class="min-w-0 flex-1">
      <span class="block text-base font-medium leading-tight truncate text-stone-700 group-hover:text-amber-700 transition-colors">
        {nome}
      </span>
      {(anoNasc || anoObit) && (
        <span class="block text-sm text-stone-400">
          {anoNasc ?? '?'}{anoObit ? ` — ${anoObit}` : ''}
        </span>
      )}
    </div>
  </a>
) : (
  <!-- Full: card com largura fixa -->
  <a
    href={`/pessoas/${pessoa.id}`}
    class="flex items-center gap-4 p-4 rounded-xl border transition-all group w-52 shrink-0 border-stone-200 bg-white hover:border-amber-400 hover:shadow-md"
  >
    <!-- Foto ou iniciais -->
    <div class="flex-shrink-0 w-12 h-12 rounded-full overflow-hidden border-2 border-stone-100">
      {thumb ? (
        <img src={thumb} alt={nome} class="w-full h-full object-cover" loading="lazy" />
      ) : (
        <img src={avatarSrc} alt="" class="w-full h-full object-cover" loading="lazy" />
      )}
    </div>
    <!-- Texto -->
    <div class="min-w-0 flex-1">
      <span class="block font-semibold leading-tight truncate text-stone-800 group-hover:text-amber-700 transition-colors">
        {nome}
      </span>
      {(anoNasc || anoObit) && (
        <span class="block text-sm text-stone-400 mt-0.5">
          {anoNasc ?? '?'}{anoObit ? ` — ${anoObit}` : ''}
        </span>
      )}
      {lugarNascLabel && (
        <span class="block text-xs text-stone-400 mt-0.5 truncate">{lugarNascLabel}</span>
      )}
    </div>
  </a>
)}
