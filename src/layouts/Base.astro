---
interface Props {
  titulo: string;
  descricao?: string;
  noindex?: boolean;
  isHome?: boolean;
  /** URL absoluta da imagem para og:image (thumbnail do retrato, etc.) */
  ogImage?: string;
}

const { titulo, descricao = '', noindex = false, isHome = false, ogImage } = Astro.props;
const siteName = 'Franquinho.info';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogTitle = isHome ? siteName : `${titulo} — ${siteName}`;
const ogImageAbsoluto = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).toString())
  : null;

const navLinks = [
  { href: '/',         label: 'Início'   },
  { href: '/arvore',   label: 'Árvore'   },
  { href: '/pessoas',  label: 'Pessoas'  },
  { href: '/lugares',  label: 'Lugares'  },
  { href: '/arquivo',  label: 'Arquivo'  },
  { href: '/pesquisa',     label: 'Pesquisa'    },
  { href: '/estatisticas', label: 'Estatísticas' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<!doctype html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{ogTitle}</title>
    {descricao && <meta name="description" content={descricao} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type"      content="website" />
    <meta property="og:url"       content={canonicalURL} />
    <meta property="og:title"     content={ogTitle} />
    {descricao && <meta property="og:description" content={descricao} />}
    {ogImageAbsoluto && <meta property="og:image" content={ogImageAbsoluto} />}

    <!-- Twitter Card -->
    <meta name="twitter:card"  content={ogImageAbsoluto ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={ogTitle} />
    {descricao && <meta name="twitter:description" content={descricao} />}
    {ogImageAbsoluto && <meta name="twitter:image" content={ogImageAbsoluto} />}
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-white text-stone-800 font-serif antialiased">

    <!-- NAVEGAÇÃO -->
    <header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-stone-100">
      <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between gap-6">

        <a href="/" class="text-sm font-bold tracking-widest uppercase text-stone-900 hover:text-amber-700 transition-colors shrink-0">
          {siteName}
        </a>

        <!-- Desktop nav -->
        <nav class="hidden sm:block">
          <ul class="flex items-center gap-1">
            {navLinks.map(({ href, label }) => {
              const ativo = pathname === href || (href !== '/' && pathname.startsWith(href));
              return (
                <li>
                  <a
                    href={href}
                    class:list={[
                      'px-3 py-1.5 rounded text-sm transition-colors',
                      ativo
                        ? 'bg-stone-900 text-white font-medium'
                        : 'text-stone-500 hover:text-stone-900 hover:bg-stone-50',
                    ]}
                  >
                    {label}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>

        <!-- Mobile: botão hambúrguer -->
        <button
          id="nav-toggle"
          class="sm:hidden flex flex-col justify-center items-center gap-1.5 w-8 h-8 shrink-0"
          aria-label="Menu"
          aria-expanded="false"
        >
          <span class="nav-bar block w-5 h-0.5 bg-stone-700 transition-all duration-200"></span>
          <span class="nav-bar block w-5 h-0.5 bg-stone-700 transition-all duration-200"></span>
          <span class="nav-bar block w-5 h-0.5 bg-stone-700 transition-all duration-200"></span>
        </button>

      </div>

      <!-- Mobile: menu dropdown -->
      <div id="nav-mobile" class="hidden sm:hidden border-t border-stone-100 bg-white/95 backdrop-blur" aria-hidden="true">
        <ul class="max-w-7xl mx-auto px-6 py-3 flex flex-col gap-1">
          {navLinks.map(({ href, label }) => {
            const ativo = pathname === href || (href !== '/' && pathname.startsWith(href));
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    'block px-3 py-2.5 rounded text-sm transition-colors',
                    ativo
                      ? 'bg-stone-900 text-white font-medium'
                      : 'text-stone-600 hover:text-stone-900 hover:bg-stone-50',
                  ]}
                >
                  {label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </header>

    <main data-pagefind-body={noindex ? undefined : true}>
      <slot />
    </main>
    <div class="min-h-[1px]"></div>

    <footer class="mt-24 border-t border-stone-100 bg-stone-50">
      <div class="max-w-7xl mx-auto px-6 py-10 flex flex-col sm:flex-row justify-between gap-4 text-xs text-stone-400">
        <span class="font-semibold tracking-wider uppercase">{siteName}</span>
        <span>Dados de pessoas vivas ou recentemente falecidas são protegidos por razões de privacidade.</span>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('nav-toggle')!;
      const menu   = document.getElementById('nav-mobile')!;
      toggle.addEventListener('click', () => {
        const open = menu.classList.toggle('hidden');
        toggle.setAttribute('aria-expanded', String(!open));
        menu.setAttribute('aria-hidden', String(open));
      });
      // Fecha ao clicar num link
      menu.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => {
          menu.classList.add('hidden');
          menu.setAttribute('aria-hidden', 'true');
          toggle.setAttribute('aria-expanded', 'false');
        })
      );
    </script>

  </body>
</html>
