---
import { readFileSync, readdirSync } from 'fs';
import { resolve } from 'path';
import Base from '../layouts/Base.astro';
import LugarLink from '../components/LugarLink.astro';
import type { Pessoa, EntradaIndice, MediaItem, Lugar, Familia } from '../types';
import { formatarData, silhueta, eRetrato } from '../utils';

const PESSOA_DESTAQUE_ID = 'I0007';

const indice: EntradaIndice[] = JSON.parse(readFileSync(resolve('src/data/indice.json'), 'utf-8'));
const lugares: Lugar[] = JSON.parse(readFileSync(resolve('src/data/lugares.json'), 'utf-8'));
const media: MediaItem[] = JSON.parse(readFileSync(resolve('src/data/media.json'), 'utf-8'));
const lugaresMap: Record<string, Lugar> = Object.fromEntries(lugares.map((l) => [l.id, l]));
const mediaMap: Record<string, MediaItem> = Object.fromEntries(media.map((m) => [m.id, m]));

const destaque: Pessoa = JSON.parse(readFileSync(resolve(`src/data/pessoas/${PESSOA_DESTAQUE_ID}.json`), 'utf-8'));

// Foto de perfil real (só retratos)
const fotoDestaque = destaque.media
  ?.map((id) => mediaMap[id]).filter(Boolean).find(eRetrato) ?? null;

const familiaComoPai: Familia[] = (destaque.familias_como_pai ?? []).map((fid) =>
  JSON.parse(readFileSync(resolve(`src/data/familias/${fid}.json`), 'utf-8'))
);
const totalFilhos = familiaComoPai.reduce((acc, f) => acc + (f.filhos?.length ?? 0), 0);
const conjugeId = familiaComoPai[0]
  ? (familiaComoPai[0].pai === PESSOA_DESTAQUE_ID ? familiaComoPai[0].mae : familiaComoPai[0].pai)
  : null;
const conjuge = conjugeId
  ? JSON.parse(readFileSync(resolve(`src/data/pessoas/${conjugeId}.json`), 'utf-8')) as Pessoa
  : null;
const lugarNasc = destaque.nascimento?.lugar_id ? lugaresMap[destaque.nascimento.lugar_id] : null;
const lugarObit = destaque.obito?.lugar_id ? lugaresMap[destaque.obito.lugar_id] : null;
const anoNasc = destaque.nascimento?.data?.match(/(\d{4})/)?.[1];
const anoObit = destaque.obito?.data?.match(/(\d{4})/)?.[1];

// Estatísticas
const totalPessoas  = readdirSync(resolve('src/data/pessoas')).filter((f) => f.endsWith('.json')).length;
const totalFamilias = readdirSync(resolve('src/data/familias')).filter((f) => f.endsWith('.json')).length;
const totalLugares  = lugares.length;
const totalFotos = media.filter((m) => m.caminho && (m.caminho_original ?? '').includes('/Fotos/')).length;
const totalDocs  = media.filter((m) => m.caminho && !(m.caminho_original ?? '').includes('/Fotos/')).length;


// Dados de aniversários para todos os dias — renderizados dinamicamente no cliente
type DadosAniversario = { id: string; nome: string; tipo: 'nascimento' | 'obito'; ano: number; thumb: string | null; sexo?: string; anoNasc?: string; anoObit?: string; mmdd: string };
const dadosAniversarios: DadosAniversario[] = [];
for (const entrada of indice) {
  const thumb = entrada.thumb_id ? (mediaMap[entrada.thumb_id]?.thumb ?? null) : null;
  const anoNascStr = entrada.ano_nasc?.toString();
  const anoObitStr = entrada.ano_obit?.toString();
  if (entrada.mmdd_nasc && entrada.ano_nasc) {
    dadosAniversarios.push({ id: entrada.id, nome: entrada.nome ?? 'Sem nome', tipo: 'nascimento', ano: entrada.ano_nasc, thumb, sexo: entrada.sexo, anoNasc: anoNascStr, anoObit: anoObitStr, mmdd: entrada.mmdd_nasc });
  }
  if (entrada.mmdd_obit && entrada.ano_obit) {
    dadosAniversarios.push({ id: entrada.id, nome: entrada.nome ?? 'Sem nome', tipo: 'obito', ano: entrada.ano_obit, thumb, sexo: entrada.sexo, anoNasc: anoNascStr, anoObit: anoObitStr, mmdd: entrada.mmdd_obit });
  }
}

const anoMaisAntigo = indice.filter(p => p.ano_nasc).sort((a,b) => (a.ano_nasc??9999)-(b.ano_nasc??9999))[0]?.ano_nasc;
---

<Base titulo="Início" isHome descricao="Árvore genealógica da família Franquinho — três séculos de história familiar">
  <link slot="head" rel="preload" href="/hero-mosaic.webp" as="image" type="image/webp" />

  <!-- ===================== HERO ===================== -->
  <section class="relative overflow-hidden" style="height: 92vh; min-height: 560px; max-height: 860px;">

    <!-- Mosaico de documentos pré-gerado em build (scripts/build-hero.py) -->
    <div class="absolute inset-0 bg-stone-900">
      <img src="/hero-mosaic.webp" alt="" class="w-full h-full object-cover opacity-60" fetchpriority="high" />
    </div>

    <!-- Gradientes -->
    <div class="absolute inset-0 bg-gradient-to-b from-stone-900/30 via-stone-900/50 to-stone-900/90"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-stone-900/60 via-transparent to-transparent"></div>

    <!-- Conteúdo -->
    <div class="relative z-10 h-full flex flex-col justify-end max-w-7xl mx-auto px-6 pb-16">
      <div class="max-w-2xl">
        <p class="text-amber-400 text-xs font-semibold uppercase tracking-[0.2em] mb-4">
          Arquivo genealógico
        </p>
        <h1 class="text-5xl sm:text-7xl font-bold text-white leading-[1.05] mb-6" style="font-family: Georgia, serif;">
          Família<br/>Franquinho
        </h1>
        <p class="text-stone-300 text-lg sm:text-xl leading-relaxed mb-8 max-w-lg">
          {anoMaisAntigo && `Desde ${anoMaisAntigo}. `}{totalPessoas} pessoas, {totalFamilias} famílias, {totalLugares} lugares documentados.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/arvore" class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-stone-900 font-semibold px-6 py-3 rounded-lg text-sm transition-colors">
            Explorar a árvore
            <span aria-hidden>&#8594;</span>
          </a>
          <a href="/pessoas" class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white border border-white/20 px-6 py-3 rounded-lg text-sm transition-colors">
            Ver todas as pessoas
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-6 right-6 z-10 text-white/30 text-xs tracking-widest uppercase hidden sm:block">
      &#8595; scroll
    </div>
  </section>

  <!-- ===================== STATS ===================== -->
  <section class="bg-stone-900 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 sm:grid-cols-5 divide-x divide-y sm:divide-y-0 divide-stone-800">
        {[
          { n: totalPessoas, label: 'Pessoas documentadas', href: '/pessoas' },
          { n: totalFamilias, label: 'Núcleos familiares',   href: '/arvore'  },
          { n: totalLugares,  label: 'Lugares referenciados',href: '/lugares' },
          { n: totalFotos,    label: 'Fotografias',          href: '/arquivo' },
          { n: totalDocs,     label: 'Documentos',           href: '/arquivo' },
        ].map(({ n, label, href }) => (
          <a href={href} class="group px-8 py-8 hover:bg-stone-800 transition-colors">
            <span class="block text-4xl font-bold text-amber-400 mb-1 group-hover:text-amber-300 transition-colors" style="font-variant-numeric: tabular-nums;">
              {n.toLocaleString('pt')}
            </span>
            <span class="text-xs text-stone-400 uppercase tracking-wide">{label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== DESTAQUE ===================== -->
  <section class="max-w-7xl mx-auto px-6 py-20">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Texto -->
      <div>
        <p class="text-sm text-stone-400 uppercase tracking-[0.15em] mb-3">Ponto de partida</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-stone-900 mb-6" style="font-family: Georgia, serif;">
          {destaque.nome}
        </h2>

        <div class="space-y-2 text-base text-stone-600 mb-8">
          {destaque.nascimento?.data && (
            <p class="flex items-baseline gap-2">
              <svg class="w-3.5 h-3.5 text-amber-400 shrink-0 self-center" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l2.55 7.85H22l-6.63 4.82 2.55 7.85L12 17.7l-5.92 4.82 2.55-7.85L2 9.85h7.45z"/>
              </svg>
              <span>
                <span class="text-stone-400">Nascido a </span>{formatarData(destaque.nascimento.data)}
                {lugarNasc && <>, <span class="text-stone-400">em </span><LugarLink lugar={lugarNasc} lugaresMap={lugaresMap} /></>}
              </span>
            </p>
          )}
          {destaque.obito?.data && (
            <p class="flex items-baseline gap-2">
              <svg class="w-3.5 h-3.5 text-stone-400 shrink-0 self-center" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11 2h2v7h7v2h-7v11h-2V11H4V9h7V2z"/>
              </svg>
              <span>
                <span class="text-stone-400">Falecido a </span>{formatarData(destaque.obito.data)}
                {lugarObit && <>, <span class="text-stone-400">em </span><LugarLink lugar={lugarObit} lugaresMap={lugaresMap} /></>}
              </span>
            </p>
          )}
        </div>

        <div class="space-y-3 text-stone-600 text-base mb-10">
          {conjuge && (
            <div class="flex gap-4">
              <span class="text-stone-400 w-28 shrink-0">Casado com</span>
              <a href={`/pessoas/${conjugeId}`} class="hover:text-amber-700 transition-colors">{conjuge.nome}</a>
            </div>
          )}
          {totalFilhos > 0 && (
            <div class="flex gap-4">
              <span class="text-stone-400 w-28 shrink-0">Filhos</span>
              <span>{totalFilhos}</span>
            </div>
          )}
          {lugarNasc && (
            <div class="flex gap-4">
              <span class="text-stone-400 w-28 shrink-0">Natural de</span>
              <LugarLink lugar={lugarNasc} lugaresMap={lugaresMap} />
            </div>
          )}
        </div>

        <a href={`/pessoas/${PESSOA_DESTAQUE_ID}`}
          class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-stone-900 font-bold px-6 py-3 rounded-xl text-base transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5">
          Ver ficha completa
          <span aria-hidden>&#8594;</span>
        </a>
      </div>

      <!-- Foto -->
      <div class="flex justify-center lg:justify-end">
        <img
          src={fotoDestaque?.thumb ?? silhueta(destaque.sexo, anoNasc, anoObit)}
          alt={destaque.nome ?? ''}
          class="w-64 h-64 sm:w-80 sm:h-80 object-cover rounded-full border-4 border-stone-100 shadow-xl"
        />
      </div>

    </div>
  </section>

  <!-- ===================== DIVISOR ===================== -->
  <div class="max-w-7xl mx-auto px-6">
    <hr class="border-stone-100" />
  </div>

  <!-- ===================== EXPLORAR ===================== -->
  <section class="max-w-7xl mx-auto px-6 py-20">
    <p class="text-xs text-stone-400 uppercase tracking-[0.15em] mb-8">Explorar o arquivo</p>

    <div class="grid sm:grid-cols-3 gap-4">
      {[
        {
          href: '/arvore',
          titulo: 'Árvore interactiva',
          desc: 'Navega entre gerações, altera o ponto de partida, muda entre modo antepassados e descendentes.',
          cor: 'bg-stone-900 text-white',
          corHover: 'hover:bg-stone-800',
        },
        {
          href: '/pessoas',
          titulo: 'Índice de pessoas',
          desc: `${totalPessoas} indivíduos com registos públicos organizados alfabeticamente, com datas e lugares.`,
          cor: 'bg-amber-50 text-stone-900',
          corHover: 'hover:bg-amber-100',
        },
        {
          href: '/arquivo',
          titulo: 'Arquivo fotográfico',
          desc: `${totalFotos} fotografias e ${totalDocs} documentos originais digitalizados, de retratos a registos de óbito.`,
          cor: 'bg-stone-50 text-stone-900',
          corHover: 'hover:bg-stone-100',
        },
      ].map(({ href, titulo, desc, cor, corHover }) => (
        <a href={href} class:list={['group rounded-2xl p-8 transition-colors', cor, corHover]}>
          <h3 class="font-bold text-lg mb-3 group-hover:underline decoration-1 underline-offset-2">{titulo}</h3>
          <p class="text-sm leading-relaxed opacity-70">{desc}</p>
          <span class="block mt-6 text-sm font-medium opacity-60 group-hover:opacity-100 transition-opacity">
            Ver &#8594;
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- ===================== ANIVERSÁRIOS DE HOJE ===================== -->
  <section class="max-w-7xl mx-auto px-6 pb-20">
    <div class="flex items-baseline justify-between mb-8">
      <p class="text-xs text-stone-400 uppercase tracking-[0.15em]">
        Aniversários de hoje
        <span id="aniversarios-data" class="ml-2 text-stone-300 normal-case tracking-normal font-normal"></span>
      </p>
      <a href="/pessoas" class="text-xs text-stone-400 hover:text-stone-900 transition-colors">Ver todas &#8594;</a>
    </div>
    <div id="aniversarios-lista">
      <p class="text-stone-400 text-sm">A carregar...</p>
    </div>
  </section>

  <script type="application/json" id="aniversarios-dados" set:html={JSON.stringify(dadosAniversarios)}></script>

  <script>
    (function () {
      const hoje = new Date();
      const mm = String(hoje.getMonth() + 1).padStart(2, '0');
      const dd = String(hoje.getDate()).padStart(2, '0');
      const mmdd = `${mm}-${dd}`;
      const anoAtual = hoje.getFullYear();

      const dataSpan = document.getElementById('aniversarios-data');
      if (dataSpan) {
        dataSpan.textContent = hoje.toLocaleDateString('pt-PT', { day: 'numeric', month: 'long' });
      }

      const raw = document.getElementById('aniversarios-dados');
      if (!raw) return;
      const dados = JSON.parse(raw.textContent ?? '[]');

      const lista = dados
        .filter((a: any) => a.mmdd === mmdd)
        .sort((a: any, b: any) => a.ano - b.ano);

      const container = document.getElementById('aniversarios-lista');
      if (!container) return;

      if (lista.length === 0) {
        container.innerHTML = '<p class="text-stone-400 text-sm">Nenhum registo de nascimento ou falecimento para hoje.</p>';
        return;
      }

      function silhueta(sexo: string | undefined, anoNasc: string | undefined, anoObit: string | undefined): string {
        const nasc = anoNasc ? parseInt(anoNasc) : null;
        const obit = anoObit ? parseInt(anoObit) : null;
        const ano = new Date().getFullYear();
        if (nasc && obit && obit - nasc < 16) return '/silhuetas/crianca_antiga.svg';
        if (nasc && !obit && ano - nasc < 16)
          return sexo === 'F' ? '/silhuetas/crianca_rapariga.svg' : '/silhuetas/crianca_rapaz.svg';
        const s = sexo === 'F' ? 'mulher' : 'homem';
        if (!nasc)       return `/silhuetas/${s}_contemporaneo.svg`;
        if (nasc < 1700) return `/silhuetas/${s}_sec17.svg`;
        if (nasc < 1800) return `/silhuetas/${s}_sec18.svg`;
        if (nasc < 1850) return `/silhuetas/${s}_sec19a.svg`;
        if (nasc < 1900) return `/silhuetas/${s}_sec19b.svg`;
        if (nasc < 1950) return `/silhuetas/${s}_sec20a.svg`;
        return `/silhuetas/${s}_contemporaneo.svg`;
      }

      function esc(s: string): string {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }

      const svgNasc = `<svg class="w-3 h-3 text-amber-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.55 7.85H22l-6.63 4.82 2.55 7.85L12 17.7l-5.92 4.82 2.55-7.85L2 9.85h7.45z"/></svg>`;
      const svgObit = `<svg class="w-3 h-3 text-stone-400" viewBox="0 0 24 24" fill="currentColor"><path d="M11 2h2v7h7v2h-7v11h-2V11H4V9h7V2z"/></svg>`;

      const grid = document.createElement('div');
      grid.className = 'grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-3';

      for (const a of lista) {
        const avatarSrc = a.thumb ?? silhueta(a.sexo, a.anoNasc, a.anoObit);
        const anos = anoAtual - a.ano;
        const isNasc = a.tipo === 'nascimento';
        const iconeBg = isNasc ? 'bg-amber-100' : 'bg-stone-100';
        const icone = isNasc ? svgNasc : svgObit;
        const primeiroNome = (a.nome || '').split(' ')[0];

        const link = document.createElement('a');
        link.href = `/pessoas/${esc(a.id)}`;
        link.className = 'group text-center';
        link.innerHTML = `
          <div class="relative">
            <div class="aspect-square rounded-full overflow-hidden mb-2 ring-2 ring-stone-100 group-hover:ring-amber-400 transition-all">
              <img src="${esc(avatarSrc)}" alt="${esc(primeiroNome)}" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-300" />
            </div>
            <div class="absolute bottom-2 right-0 w-5 h-5 rounded-full ${iconeBg} flex items-center justify-center shadow-sm">
              ${icone}
            </div>
          </div>
          <p class="text-xs text-stone-600 group-hover:text-stone-900 transition-colors leading-tight truncate px-1 font-medium">${esc(primeiroNome)}</p>
          <p class="text-xs text-stone-400">${esc(String(a.ano))} · ${esc(String(anos))} anos</p>
        `;
        grid.appendChild(link);
      }

      container.replaceChildren(grid);
    })();
  </script>

</Base>
