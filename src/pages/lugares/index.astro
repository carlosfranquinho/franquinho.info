---
import { readFileSync, readdirSync } from 'fs';
import { resolve } from 'path';
import Base from '../../layouts/Base.astro';
import type { Lugar, Pessoa } from '../../types';

const lugares: Lugar[] = JSON.parse(readFileSync(resolve('src/data/lugares.json'), 'utf-8'));
const lugaresMap: Record<string, Lugar> = Object.fromEntries(lugares.map((l) => [l.id, l]));

// ─── Contagem de pessoas por lugar ────────────────────────────────────────────

const contagemDireta: Record<string, number> = {};
const pessoasDir = resolve('src/data/pessoas');
for (const f of readdirSync(pessoasDir)) {
  if (!f.endsWith('.json')) continue;
  const p: Pessoa = JSON.parse(readFileSync(resolve(pessoasDir, f), 'utf-8'));
  if (p.protegida) continue;
  for (const lid of [p.nascimento?.lugar_id, p.obito?.lugar_id, p.baptismo?.lugar_id, p.sepultura?.lugar_id]) {
    if (lid) contagemDireta[lid] = (contagemDireta[lid] ?? 0) + 1;
  }
}

function totalComFilhos(lid: string): number {
  const filhos = lugares.filter((l) => l.pai_id === lid);
  return (contagemDireta[lid] ?? 0) + filhos.reduce((s, f) => s + totalComFilhos(f.id), 0);
}

// ─── Estrutura: país > distrito > município > freguesias ──────────────────────

type Freguesia   = { lugar: Lugar; total: number };
type Municipio   = { lugar: Lugar; total: number; freguesias: Freguesia[] };
type Distrito    = { lugar: Lugar; total: number; municipios: Municipio[] };
type Pais        = { lugar: Lugar; total: number; distritos: Distrito[] };

const paisesReais = lugares.filter((l) => {
  if (l.pai_id) return false;
  return !(l.nome ?? '').includes(',');
});

function buildPais(pais: Lugar): Pais {
  const distritos = lugares
    .filter((l) => l.pai_id === pais.id)
    .map((d): Distrito => {
      const municipios = lugares
        .filter((l) => l.pai_id === d.id)
        .map((m): Municipio => {
          const freguesias = lugares
            .filter((l) => l.pai_id === m.id)
            .map((fr): Freguesia => ({ lugar: fr, total: totalComFilhos(fr.id) }))
            .filter((fr) => fr.total > 0)
            .sort((a, b) => b.total - a.total);
          return { lugar: m, total: totalComFilhos(m.id), freguesias };
        })
        .filter((m) => m.total > 0)
        .sort((a, b) => b.total - a.total);
      return { lugar: d, total: totalComFilhos(d.id), municipios };
    })
    .filter((d) => d.total > 0)
    .sort((a, b) => b.total - a.total);
  return { lugar: pais, total: totalComFilhos(pais.id), distritos };
}

const arvore = paisesReais
  .map(buildPais)
  .filter((p) => p.total > 0)
  .sort((a, b) => b.total - a.total);

// Totais globais
const totalPessoas = Object.values(contagemDireta).reduce((s, n) => s + n, 0);
const totalFreguesias = lugares.filter((l) => {
  let d = 0, cur = lugaresMap[l.id];
  while (cur?.pai_id) { d++; cur = lugaresMap[cur.pai_id]; }
  return d === 3 && totalComFilhos(l.id) > 0;
}).length;
---

<Base titulo="Lugares" descricao="Lugares referenciados na árvore genealógica Franquinho.info">
  <div class="max-w-7xl mx-auto px-6 py-10">

    <!-- Cabeçalho -->
    <div class="flex items-baseline justify-between border-b border-stone-200 pb-4 mb-8">
      <h1 class="text-2xl font-bold text-stone-800">Lugares</h1>
      <span class="text-sm text-stone-500">
        {totalFreguesias} freguesias &nbsp;·&nbsp; {totalPessoas} pessoas
      </span>
    </div>

    <!-- Painéis por país -->
    <div class="space-y-6">
      {arvore.map((pais) => (
        <section class="rounded-2xl border border-stone-200 overflow-hidden shadow-sm">

          <!-- Cabeçalho do país -->
          <div class="bg-stone-800 px-6 py-4 flex items-center justify-between">
            <h2 class="text-base font-bold text-white tracking-wide">{pais.lugar.nome}</h2>
            <span class="text-xs text-stone-400 font-medium">{pais.total} pessoas</span>
          </div>

          <!-- Grelha de distritos -->
          <div class="p-5 bg-stone-50/60">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
              {pais.distritos.map((distrito) => (
                <div class="bg-white rounded-xl border border-stone-200 overflow-hidden">

                  <!-- Botão do distrito -->
                  <button
                    class="district-btn w-full flex items-center justify-between px-4 py-3 hover:bg-amber-50 transition-colors text-left gap-2"
                    data-target={`muns-${distrito.lugar.id}`}
                    aria-expanded="false"
                  >
                    <span class="font-semibold text-stone-800 text-sm leading-snug">{distrito.lugar.nome}</span>
                    <div class="flex items-center gap-2 shrink-0">
                      <span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full font-semibold">
                        {distrito.total}
                      </span>
                      <svg class="chevron w-4 h-4 text-stone-400 transition-transform duration-200 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </div>
                  </button>

                  <!-- Lista de municípios (oculta inicialmente) -->
                  <div id={`muns-${distrito.lugar.id}`} class="hidden border-t border-stone-100 divide-y divide-stone-100">
                    {distrito.municipios.map((municipio) => (
                      <div>
                        {municipio.freguesias.length > 0 && (
                          <button
                            class="mun-btn w-full flex items-center justify-between px-4 py-2.5 hover:bg-stone-50 transition-colors text-left gap-2"
                            data-target={`frs-${municipio.lugar.id}`}
                            aria-expanded="false"
                          >
                            <span class="text-sm text-stone-700 font-medium">{municipio.lugar.nome}</span>
                            <div class="flex items-center gap-1.5 shrink-0">
                              <span class="text-xs text-stone-400">{municipio.total}</span>
                              <svg class="chevron w-3 h-3 text-stone-400 transition-transform duration-200 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                              </svg>
                            </div>
                          </button>
                        )}
                        {municipio.freguesias.length > 0 && (
                          <div id={`frs-${municipio.lugar.id}`} class="hidden px-4 py-3 flex flex-wrap gap-1.5 bg-stone-50/80">
                            {municipio.freguesias.map(({ lugar, total }) => (
                              <a
                                href={`/lugares/${lugar.id}`}
                                class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-full border border-stone-200 bg-white text-stone-600 hover:border-amber-400 hover:text-amber-700 hover:shadow-sm transition-all"
                              >
                                {lugar.nome}
                                <span class="text-stone-400">{total}</span>
                              </a>
                            ))}
                          </div>
                        )}
                        {municipio.freguesias.length === 0 && (
                          <a
                            href={`/lugares/${municipio.lugar.id}`}
                            class="flex items-center justify-between px-4 py-2.5 hover:bg-stone-50 transition-colors group"
                          >
                            <span class="text-sm text-stone-700 font-medium group-hover:text-amber-700 transition-colors">{municipio.lugar.nome}</span>
                            <span class="text-xs text-stone-400">{municipio.total}</span>
                          </a>
                        )}
                      </div>
                    ))}
                    {/* Distrito sem municípios intermédios mas com pessoas — link directo */}
                    {distrito.municipios.length === 0 && (
                      <a
                        href={`/lugares/${distrito.lugar.id}`}
                        class="flex items-center justify-between px-4 py-2.5 hover:bg-stone-50 transition-colors group"
                      >
                        <span class="text-sm text-stone-700 font-medium group-hover:text-amber-700 transition-colors">Ver registos</span>
                        <span class="text-xs text-stone-400">{distrito.total}</span>
                      </a>
                    )}
                  </div>

                </div>
              ))}
            </div>
          </div>

        </section>
      ))}
    </div>

  </div>
</Base>

<script>
  function togglePanel(btn: HTMLElement) {
    const targetId = btn.dataset.target;
    if (!targetId) return;
    const panel = document.getElementById(targetId);
    if (!panel) return;
    const isOpen = !panel.classList.contains('hidden');
    panel.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.querySelector<SVGElement>('.chevron')?.classList.toggle('rotate-180', !isOpen);
  }

  document.querySelectorAll<HTMLElement>('.district-btn').forEach((btn) =>
    btn.addEventListener('click', () => togglePanel(btn))
  );
  document.querySelectorAll<HTMLElement>('.mun-btn').forEach((btn) =>
    btn.addEventListener('click', () => togglePanel(btn))
  );
</script>
