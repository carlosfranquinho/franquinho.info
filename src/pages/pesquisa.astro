---
import Base from '../layouts/Base.astro';
---

<Base titulo="Pesquisa" descricao="Pesquisa por nome, lugar e data">
  <div class="max-w-7xl mx-auto px-6 py-10 space-y-6">

    <div class="border-b border-stone-200 pb-4">
      <h1 class="text-2xl font-bold text-stone-800">Pesquisa</h1>
    </div>

    <div id="search"></div>

  </div>
</Base>

<!-- Pagefind UI — carregado do bundle gerado pelo build -->
<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" type="text/javascript"></script>
<script>
  // @ts-ignore
  new PagefindUI({ element: '#search', showImages: true });
</script>
