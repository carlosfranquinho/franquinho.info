---
import { readFileSync } from 'fs';
import { resolve } from 'path';
import Base from '../layouts/Base.astro';
import TreeView from '../components/TreeView.jsx';
import type { Pessoa } from '../types';

const ROOT_ID = 'I0007';
const root: Pessoa = JSON.parse(readFileSync(resolve(`src/data/pessoas/${ROOT_ID}.json`), 'utf-8'));
const rootName = root.nome ?? ROOT_ID;
---

<Base titulo="Arvore" descricao="Arvore genealogica interactiva da familia Franquinho">
  <div class="space-y-4">

    <div class="flex items-baseline justify-between border-b border-stone-200 pb-4">
      <h1 class="text-2xl font-bold text-stone-800">Árvore interactiva</h1>
      <span class="text-xs text-stone-400">Clique num nó para ver opções · Pesquise para navegar</span>
    </div>

    <!-- Contentor com altura fixa para o ReactFlow -->
    <div class="rounded-xl overflow-hidden border border-stone-200 shadow-sm" style="height: 70vh; min-height: 500px;">
      <TreeView
        client:load
        defaultRootId={ROOT_ID}
        defaultRootName={rootName}
      />
    </div>

  </div>
</Base>
