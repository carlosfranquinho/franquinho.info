---
import { readFileSync } from 'fs';
import { resolve } from 'path';
import Base from '../../layouts/Base.astro';
import type { EntradaIndice } from '../../types';

const pessoas: EntradaIndice[] = JSON.parse(readFileSync(resolve('src/data/indice.json'), 'utf-8'));

// Agrupar por primeira letra do nome
const grupos: Record<string, EntradaIndice[]> = {};
for (const p of pessoas) {
  const letra = p.nome ? p.nome[0].toUpperCase() : '#';
  if (!grupos[letra]) grupos[letra] = [];
  grupos[letra].push(p);
}
const letras = Object.keys(grupos).sort();
---

<Base titulo="Pessoas" descricao="Indice alfabetico de todas as pessoas na arvore genealogica">

  <div class="max-w-7xl mx-auto px-6 py-10 space-y-6">

    <div class="flex items-baseline justify-between border-b border-stone-200 pb-4">
      <h1 class="text-2xl font-bold text-stone-800">Pessoas</h1>
      <span class="text-sm text-stone-500">{pessoas.length} registos publicos</span>
    </div>

    <!-- Indice rapido por letra -->
    <nav aria-label="Indice alfabetico" class="flex flex-wrap gap-1">
      {letras.map((letra) => (
        <a
          href={`#letra-${letra}`}
          class="px-2 py-0.5 text-sm border border-stone-300 rounded hover:bg-amber-100 hover:border-amber-400 transition-colors"
        >
          {letra}
        </a>
      ))}
    </nav>

    <!-- Grupos por letra -->
    {letras.map((letra) => (
      <section id={`letra-${letra}`} class="scroll-mt-4">
        <h2 class="text-lg font-bold text-amber-700 border-b border-amber-200 pb-1 mb-3">{letra}</h2>
        <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2">
          {grupos[letra]
            .sort((a, b) => (a.nome ?? '').localeCompare(b.nome ?? '', 'pt'))
            .map((p) => (
              <li>
                <a
                  href={`/pessoas/${p.id}`}
                  class="flex justify-between items-center px-3 py-2 bg-white border border-stone-200 rounded hover:border-amber-400 transition-colors group"
                >
                  <span class="text-sm text-stone-700 group-hover:text-amber-700 transition-colors">
                    {p.nome ?? <em class="text-stone-400">Sem nome</em>}
                  </span>
                  <span class="text-xs text-stone-400 ml-2 flex-shrink-0">
                    {p.ano_nasc ?? ''}
                    {p.ano_nasc && p.ano_obit ? ` — ${p.ano_obit}` : ''}
                    {!p.ano_nasc && p.ano_obit ? `† ${p.ano_obit}` : ''}
                  </span>
                </a>
              </li>
            ))}
        </ul>
      </section>
    ))}

  </div>
</Base>
