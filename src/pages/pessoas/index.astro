---
import { readFileSync } from 'fs';
import { resolve } from 'path';
import Base from '../../layouts/Base.astro';
import type { EntradaIndice } from '../../types';

const todasPessoas: EntradaIndice[] = JSON.parse(readFileSync(resolve('src/data/indice.json'), 'utf-8'));
const pessoas = todasPessoas.filter(
  (p) => p.nome && !p.nome.startsWith('Privado')
);
---

<Base titulo="Pessoas" descricao="Indice alfabetico de todas as pessoas na arvore genealogica">

  <div class="max-w-7xl mx-auto px-6 py-10 space-y-6">

    <div class="flex items-baseline justify-between border-b border-stone-200 pb-4">
      <h1 class="text-2xl font-bold text-stone-800">Pessoas</h1>
      <span class="text-sm text-stone-500">{pessoas.length} registos publicos</span>
    </div>

    <!-- Toggle nome / apelido -->
    <div class="flex gap-1 p-1 bg-stone-100 rounded-lg w-fit">
      <button id="btn-nome" class="px-4 py-1.5 text-sm rounded-md font-medium transition-colors bg-white text-stone-800 shadow-sm">
        Nome próprio
      </button>
      <button id="btn-apelido" class="px-4 py-1.5 text-sm rounded-md font-medium transition-colors text-stone-500 hover:text-stone-700">
        Apelido
      </button>
    </div>

    <!-- Índice rápido por letra -->
    <nav id="nav-letras" aria-label="Indice alfabetico" class="flex flex-wrap gap-1"></nav>

    <!-- Grupos por letra -->
    <div id="lista-pessoas"></div>

  </div>
</Base>

<script type="application/json" id="pessoas-dados" set:html={JSON.stringify(pessoas)}></script>

<script>
  const dados: any[] = JSON.parse((document.getElementById('pessoas-dados') as HTMLElement).textContent ?? '[]');

  let modoAtual: 'nome' | 'apelido' = 'nome';

  const SEM_APELIDO = '§'; // sentinel que ordena depois de Z

  // Remove preposições iniciais do apelido para ordenação e agrupamento
  const PREFIXOS = /^(d[aeiou]s?|d'|do|von|van|e)\s+/i;
  function semPrefixo(s: string): string {
    return s.replace(PREFIXOS, '').trimStart();
  }

  function chave(p: any, modo: 'nome' | 'apelido'): string {
    if (modo === 'apelido') return p.apelido ? semPrefixo(p.apelido)[0].toUpperCase() : SEM_APELIDO;
    return p.nome ? p.nome[0].toUpperCase() : '#';
  }

  function textoOrdenacao(p: any, modo: 'nome' | 'apelido'): string {
    if (modo === 'apelido') return p.apelido ? semPrefixo(p.apelido) : (p.nome ?? '');
    return p.nome ?? '';
  }

  function esc(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function render(modo: 'nome' | 'apelido') {
    // Agrupar
    const grupos: Record<string, any[]> = {};
    for (const p of dados) {
      const letra = chave(p, modo);
      if (!grupos[letra]) grupos[letra] = [];
      grupos[letra].push(p);
    }
    const letras = Object.keys(grupos).sort();

    // Índice de letras (excluir sentinel)
    const nav = document.getElementById('nav-letras')!;
    nav.innerHTML = letras.filter((l) => l !== SEM_APELIDO).map((l) =>
      `<a href="#letra-${esc(l)}" class="px-2 py-0.5 text-sm border border-stone-300 rounded hover:bg-amber-100 hover:border-amber-400 transition-colors">${esc(l)}</a>`
    ).join('');

    // Lista
    const lista = document.getElementById('lista-pessoas')!;
    lista.innerHTML = letras.map((letra) => {
      const entradas = grupos[letra]
        .slice()
        .sort((a: any, b: any) => textoOrdenacao(a, modo).localeCompare(textoOrdenacao(b, modo), 'pt'));

      const items = entradas.map((p: any) => {
        const nome = p.nome ? esc(p.nome) : '<em class="text-stone-400">Sem nome</em>';
        const apelido = p.apelido ? `<span class="text-stone-400 ml-1">· ${esc(p.apelido)}</span>` : '';
        const datas = (() => {
          if (p.ano_nasc && p.ano_obit) return `${p.ano_nasc} — ${p.ano_obit}`;
          if (p.ano_nasc) return String(p.ano_nasc);
          if (p.ano_obit) return `† ${p.ano_obit}`;
          return '';
        })();
        return `<li>
          <a href="/pessoas/${esc(p.id)}" class="flex justify-between items-center px-3 py-2 bg-white border border-stone-200 rounded hover:border-amber-400 transition-colors group">
            <span class="text-sm text-stone-700 group-hover:text-amber-700 transition-colors">
              ${modo === 'apelido' && p.apelido
                ? `<span class="font-medium">${esc(p.apelido)}</span><span class="text-stone-400">, ${esc(p.nome ?? '')}</span>`
                : nome
              }
            </span>
            <span class="text-xs text-stone-400 ml-2 flex-shrink-0">${esc(datas)}</span>
          </a>
        </li>`;
      }).join('');

      const titulo = letra === SEM_APELIDO ? 'Sem apelido' : letra;
      return `<section id="letra-${esc(letra)}" class="scroll-mt-4">
        <h2 class="text-lg font-bold text-amber-700 border-b border-amber-200 pb-1 mb-3">${esc(titulo)}</h2>
        <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2">${items}</ul>
      </section>`;
    }).join('<div class="space-y-6"></div>');
  }

  function setModo(modo: 'nome' | 'apelido') {
    modoAtual = modo;
    const btnNome    = document.getElementById('btn-nome')!;
    const btnApelido = document.getElementById('btn-apelido')!;
    if (modo === 'nome') {
      btnNome.className    = 'px-4 py-1.5 text-sm rounded-md font-medium transition-colors bg-white text-stone-800 shadow-sm';
      btnApelido.className = 'px-4 py-1.5 text-sm rounded-md font-medium transition-colors text-stone-500 hover:text-stone-700';
    } else {
      btnApelido.className = 'px-4 py-1.5 text-sm rounded-md font-medium transition-colors bg-white text-stone-800 shadow-sm';
      btnNome.className    = 'px-4 py-1.5 text-sm rounded-md font-medium transition-colors text-stone-500 hover:text-stone-700';
    }
    render(modo);
  }

  document.getElementById('btn-nome')!.addEventListener('click', () => setModo('nome'));
  document.getElementById('btn-apelido')!.addEventListener('click', () => setModo('apelido'));

  render('nome');
</script>
